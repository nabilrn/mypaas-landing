---
import {
  siCaddy,
  siCloudflare,
  siDocker,
  siGit,
  siGithub,
  siLinux,
  siPostgresql,
} from "simple-icons";

const integrations = [
  { name: "GitHub", role: "Source, OAuth, webhooks", icon: siGithub },
  { name: "Git", role: "Repository input", icon: siGit },
  { name: "Docker", role: "Build and runtime", icon: siDocker },
  { name: "Docker Compose", role: "Multi-service projects", icon: siDocker },
  { name: "Caddy", role: "Internal routing", icon: siCaddy },
  { name: "Cloudflare", role: "Tunnel and public TLS", icon: siCloudflare },
  { name: "PostgreSQL", role: "Platform state and shared DB", icon: siPostgresql },
  { name: "Linux", role: "Host operating system", icon: siLinux },
];
---

<div class="marquee" aria-label="Technology integrations">
  <div class="marquee-track">
    {[0, 1].map((group) => (
      <div class="marquee-group" aria-hidden={group === 1 ? "true" : undefined}>
        {integrations.map((item) => (
          <div class="integration-item">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d={item.icon.path}></path>
            </svg>
            <span>
              <strong>{item.name}</strong>
              <small>{item.role}</small>
            </span>
          </div>
        ))}
      </div>
    ))}
  </div>
</div>

<style>
  .marquee {
    overflow: hidden;
    border-block: 1px solid var(--app-border);
    background: var(--app-surface);
  }

  .marquee-track,
  .marquee-group {
    display: flex;
    align-items: stretch;
  }

  .marquee-track {
    width: max-content;
    animation: marquee 42s linear infinite;
  }

  .marquee-group {
    flex-shrink: 0;
  }

  .integration-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 15.5rem;
    padding: 1rem 1.15rem;
    border-right: 1px solid var(--app-border);
  }

  svg {
    width: 1.35rem;
    height: 1.35rem;
    flex: 0 0 auto;
    fill: currentColor;
    color: var(--app-ink);
  }

  span {
    display: grid;
    gap: 0.1rem;
  }

  strong {
    font-size: 0.78rem;
    font-weight: 620;
  }

  small {
    color: var(--app-subtle);
    font-size: 0.66rem;
  }

  @keyframes marquee {
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      width: auto;
      animation: none;
    }

    .marquee-group {
      flex-wrap: wrap;
    }

    .marquee-group[aria-hidden="true"] {
      display: none;
    }
  }
</style>
