---
import { Image } from "astro:assets";

interface Props {
  lightSrc?: string;
  darkSrc?: string;
}

const {
  lightSrc = "/landing/dashboard-light.png",
  darkSrc = "/landing/dashboard-dark.png",
} = Astro.props;
---

<figure class="compare-shell" aria-label="MyPaas dashboard theme comparison" data-compare-shell>
  <div class="compare-stage" style="--reveal: 50%" data-compare-stage>
    <Image
      class="compare-image compare-image-light"
      src={lightSrc}
      alt="MyPaas deployment dashboard in light mode"
      width="1920"
      height="915"
      loading="eager"
      decoding="async"
      draggable="false"
    />
    <Image
      class="compare-image compare-image-dark"
      src={darkSrc}
      alt=""
      aria-hidden="true"
      width="1920"
      height="915"
      loading="eager"
      decoding="async"
      draggable="false"
    />

    <input
      class="compare-input"
      type="range"
      min="0"
      max="100"
      step="1"
      value="50"
      aria-label="Compare light and dark MyPaas dashboard themes"
      aria-valuetext="50% dark theme shown"
      data-compare-input
    />

    <div class="compare-divider" aria-hidden="true"></div>
    <div class="compare-handle" aria-hidden="true">
      <span>‹</span><span>›</span>
    </div>

    <div class="privacy-mask" aria-hidden="true">
      <span>Workspace details hidden</span>
    </div>
  </div>
</figure>

<script>
  document.querySelectorAll<HTMLElement>("[data-compare-shell]").forEach((shell) => {
    const stage = shell.querySelector<HTMLElement>("[data-compare-stage]");
    const input = shell.querySelector<HTMLInputElement>("[data-compare-input]");
    let frameId: number | null = null;
    let timer: number | null = null;
    let animating = false;

    const setPosition = (position: number) => {
      stage?.style.setProperty("--reveal", `${position}%`);
      if (input) {
        input.value = String(position);
        input.setAttribute("aria-valuetext", `${Math.round(position)}% dark theme shown`);
      }
    };

    const stop = () => {
      animating = false;
      if (frameId !== null) cancelAnimationFrame(frameId);
      if (timer !== null) clearTimeout(timer);
      frameId = null;
      timer = null;
    };

    const ease = (value: number) => value < 0.5
      ? 2 * value * value
      : 1 - Math.pow(-2 * value + 2, 2) / 2;

    const demo = () => {
      stop();
      if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      animating = true;
      const startedAt = performance.now();

      const tick = (now: number) => {
        if (!animating) return;
        const progress = Math.min((now - startedAt) / 1500, 1);
        const position = progress <= 0.66
          ? 24 + 52 * ease(progress / 0.66)
          : 76 - 26 * ease((progress - 0.66) / 0.34);
        setPosition(position);

        if (progress < 1) frameId = requestAnimationFrame(tick);
        else {
          stop();
          setPosition(50);
        }
      };

      frameId = requestAnimationFrame(tick);
    };

    input?.addEventListener("input", () => {
      stop();
      setPosition(Number(input.value));
    });
    input?.addEventListener("pointerdown", stop);
    input?.addEventListener("keydown", stop);
    timer = window.setTimeout(demo, 500);
  });
</script>

<style>
  .compare-shell {
    margin: 0;
    overflow: hidden;
    border: 1px solid var(--app-border-strong);
    border-radius: 0.6rem;
    background: var(--app-surface);
    box-shadow: 0 24px 60px rgb(15 23 42 / 0.12);
  }

  .compare-stage {
    position: relative;
    isolation: isolate;
    aspect-ratio: 1920 / 915;
    overflow: hidden;
    background: oklch(0.145 0.012 255);
    user-select: none;
  }

  .compare-image {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: left top;
    pointer-events: none;
  }

  .compare-image-dark {
    clip-path: inset(0 calc(100% - var(--reveal)) 0 0);
  }

  .compare-input {
    position: absolute;
    z-index: 5;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    opacity: 0;
    cursor: ew-resize;
    touch-action: pan-y;
  }

  .compare-divider {
    position: absolute;
    z-index: 3;
    top: 0;
    bottom: 0;
    left: var(--reveal);
    width: 2px;
    background: white;
    box-shadow: 0 0 0 1px rgb(2 6 23 / 0.2), 0 0 18px rgb(2 6 23 / 0.35);
    transform: translateX(-50%);
    pointer-events: none;
  }

  .compare-handle {
    position: absolute;
    z-index: 6;
    top: 50%;
    left: clamp(1.5rem, var(--reveal), calc(100% - 1.5rem));
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    width: 3rem;
    height: 3rem;
    border: 2px solid white;
    border-radius: 999px;
    background: var(--app-accent-strong);
    color: white;
    box-shadow: 0 8px 24px rgb(2 6 23 / 0.3);
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .compare-handle span {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    line-height: 1;
  }

  .compare-input:focus-visible ~ .compare-handle {
    box-shadow: 0 0 0 2px var(--app-surface), 0 0 0 5px var(--app-accent);
  }

  .privacy-mask {
    position: absolute;
    z-index: 4;
    left: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 15.65%;
    height: 15.85%;
    border-top: 1px solid rgb(255 255 255 / 0.16);
    border-right: 1px solid rgb(255 255 255 / 0.16);
    background: rgb(8 15 25 / 0.18);
    backdrop-filter: blur(15px);
    pointer-events: none;
  }

  .privacy-mask span {
    max-width: 8rem;
    padding: 0.3rem 0.45rem;
    border: 1px solid rgb(255 255 255 / 0.2);
    border-radius: 0.25rem;
    background: rgb(3 11 20 / 0.72);
    color: rgb(255 255 255 / 0.84);
    font-size: clamp(0.38rem, 0.56vw, 0.65rem);
    font-weight: 600;
    line-height: 1.2;
    text-align: center;
  }

  @media (max-width: 720px) {
    .compare-stage {
      aspect-ratio: 4 / 3;
    }

    .compare-image {
      object-position: 20% top;
    }

    .privacy-mask {
      width: 18%;
    }
  }
</style>
